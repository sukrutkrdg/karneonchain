# ---- Uygulama ----
# Deploy edilen tam URL (manifest, embed ve kart meta'ları için). Yerelde: http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="PnL Pasaportu"

# ---- OnchainKit / MiniKit ----
# Coinbase Developer Platform API anahtarı (https://portal.cdp.coinbase.com)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# ---- Veri katmanı (Faz 1: Zerion) ----
# https://developers.zerion.io — Basic <base64(apikey:)> formatında kullanılır.
ZERION_API_KEY=
# Hangi sağlayıcı aktif: "zerion" (faz 1) | "indexer" (faz 2, ileride)
PNL_PROVIDER=zerion

# ---- Cache / bildirim (Upstash Redis) ----
# https://console.upstash.com — opsiyonel; yoksa bellek-içi cache'e düşer.
REDIS_URL=
REDIS_TOKEN=

# ---- Farcaster Manifest sahiplik ispatı (npx create-onchain --manifest ile üretilir) ----
# Gerçek deploy domain'i ile imzalanmalı.
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=
